{
	"name": "df_silver_to_gold_dim_paquete",
	"properties": {
		"folder": {
			"name": "silver_to_gold/dim"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_sql_silver_sup_catalogo_paquetes2",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sql_gold_paquete",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          paquete_id as integer,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as decimal(10,2),",
				"          costo_estimado_bs as decimal(10,2),",
				"          fecha_procesamiento as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 derive(nombre = trim(upper(nombre)),",
				"          contenido = trim(upper(contenido))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          paquete_key as integer,",
				"          paquete_id as integer,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as decimal(10,2),",
				"          costo_estimado_bs as decimal(10,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          paquete_id,",
				"          nombre,",
				"          contenido,",
				"          peso_estandar_kg,",
				"          costo_estimado_bs",
				"     )) ~> sink1"
			]
		}
	}
}