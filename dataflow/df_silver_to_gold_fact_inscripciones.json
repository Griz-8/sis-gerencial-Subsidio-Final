{
	"name": "df_silver_to_gold_fact_inscripciones",
	"properties": {
		"folder": {
			"name": "silver_to_gold/fact"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_sql_silver_sup_inscripciones",
						"type": "DatasetReference"
					},
					"name": "SilverInscripciones"
				},
				{
					"dataset": {
						"referenceName": "ds_sql_gold_beneficiaria",
						"type": "DatasetReference"
					},
					"name": "GoldDimBeneficiaria"
				},
				{
					"dataset": {
						"referenceName": "ds_sql_gold_establecimiento",
						"type": "DatasetReference"
					},
					"name": "GoldDimEstablecimiento"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sql_gold_fact_inscripciones",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "PrepInscrip"
				},
				{
					"name": "join1"
				},
				{
					"name": "join2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          inscripcion_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          fecha_inscripcion as date,",
				"          semana_gestacion as integer,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SilverInscripciones",
				"source(output(",
				"          beneficiaria_key as integer,",
				"          ci as string,",
				"          nombre_completo as string,",
				"          fecha_nacimiento as date,",
				"          genero as string,",
				"          estado_civil as string,",
				"          municipio as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> GoldDimBeneficiaria",
				"source(output(",
				"          establecimiento_key as integer,",
				"          establecimiento_id as integer,",
				"          nombre as string,",
				"          codigo_snis as string,",
				"          nivel_atencion as string,",
				"          red_salud as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> GoldDimEstablecimiento",
				"SilverInscripciones derive(tiempo_key = toInteger(toString(fecha_inscripcion, 'yyyyMMdd')),",
				"          cantidad_inscripciones = 1) ~> PrepInscrip",
				"PrepInscrip, GoldDimBeneficiaria join(ci_beneficiaria == ci,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1, GoldDimEstablecimiento join(SilverInscripciones@establecimiento_id == GoldDimEstablecimiento@establecimiento_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"join2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          inscripcion_key as integer,",
				"          inscripcion_id as integer,",
				"          tiempo_key as integer,",
				"          beneficiaria_key as integer,",
				"          establecimiento_key as integer,",
				"          semana_gestacion as integer,",
				"          estado_inscripcion as string,",
				"          cantidad_inscripciones as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          inscripcion_id,",
				"          tiempo_key,",
				"          beneficiaria_key,",
				"          establecimiento_key,",
				"          semana_gestacion,",
				"          estado_inscripcion = SilverInscripciones@estado,",
				"          cantidad_inscripciones",
				"     )) ~> sink1"
			]
		}
	}
}