{
	"name": "df_bronze_to_silver_inscripciones",
	"properties": {
		"folder": {
			"name": "bronze_to_silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_sql_bronze_sup_inscripciones",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sql_silver_sup_inscripciones",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          inscripcion_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          fecha_inscripcion as string,",
				"          semana_gestacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 derive(inscripcion_id = toInteger(inscripcion_id),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          semana_gestacion = toInteger(semana_gestacion),",
				"          fecha_inscripcion = iif(     instr(toString(fecha_inscripcion), '-') > 0,     toDate(toString(fecha_inscripcion), 'yyyy-MM-dd'),     iif(         toInteger(left(toString(fecha_inscripcion),2)) > 12,         toDate(toString(fecha_inscripcion), 'dd/MM/yyyy'),         toDate(toString(fecha_inscripcion), 'MM/dd/yyyy')     ) ),",
				"          estado = trim(estado)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          inscripcion_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          fecha_inscripcion as date,",
				"          semana_gestacion as integer,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          inscripcion_id,",
				"          ci_beneficiaria,",
				"          establecimiento_id,",
				"          fecha_inscripcion,",
				"          semana_gestacion,",
				"          estado",
				"     )) ~> sink1"
			]
		}
	}
}