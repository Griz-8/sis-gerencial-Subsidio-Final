{
	"name": "df_bronze_to_silver_as_recepciones",
	"properties": {
		"folder": {
			"name": "bronze_to_silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_sql_bronze_as_recepciones",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sql_silver_as_recepciones",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          recepcion_id as string,",
				"          nro_lote as string,",
				"          almacen_id as string,",
				"          transportista_id as string,",
				"          vehiculo_id as string,",
				"          fecha_recepcion as string,",
				"          cantidad_recibida as string,",
				"          unidad as string,",
				"          condicion as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_remision as string,",
				"          temperatura_llegada as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 derive(recepcion_id = toInteger(recepcion_id),",
				"          fecha_recepcion = iif(     instr(fecha_recepcion, '/') > 0,     toDate(fecha_recepcion, 'dd/MM/yyyy'),     iif(         instr(fecha_recepcion, '-') == 3,         toDate(fecha_recepcion, 'dd-MM-yyyy'),         toDate(fecha_recepcion, 'yyyy-MM-dd')     ) ),",
				"          cantidad_recibida = toDecimal(cantidad_recibida, 18, 2),",
				"          temperatura_llegada = toDecimal(temperatura_llegada, 5, 2),",
				"          almacen_id = toInteger(almacen_id),",
				"          transportista_id = toInteger(transportista_id),",
				"          vehiculo_id = toInteger(vehiculo_id)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          recepcion_id as integer,",
				"          nro_lote as string,",
				"          condicion as string,",
				"          estado as string,",
				"          almacen_id as integer,",
				"          transportista_id as integer,",
				"          vehiculo_id as integer,",
				"          fecha_recepcion as date,",
				"          cantidad_recibida as decimal(18,2),",
				"          unidad as string,",
				"          responsable as string,",
				"          nro_guia_remision as string,",
				"          temperatura_llegada as decimal(5,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          recepcion_id,",
				"          nro_lote,",
				"          condicion,",
				"          estado,",
				"          almacen_id,",
				"          transportista_id,",
				"          vehiculo_id,",
				"          fecha_recepcion,",
				"          cantidad_recibida,",
				"          unidad,",
				"          responsable,",
				"          nro_guia_remision,",
				"          temperatura_llegada",
				"     )) ~> sink1"
			]
		}
	}
}