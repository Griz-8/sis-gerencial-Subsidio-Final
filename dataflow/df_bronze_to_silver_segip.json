{
	"name": "df_bronze_to_silver_segip",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_csv_segip",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sql_silver_segip",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn2"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CI as string,",
				"          Nombres as string,",
				"          {Ap. Paterno} as string,",
				"          {Ap. Materno} as string,",
				"          {Fecha Nac.} as string,",
				"          {Género} as string,",
				"          {Estado Civil} as string,",
				"          Municipio as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"select1 derive(ci = upper(iif(rlike(regexReplace(ci, '[-_]', ''), '^[A-Za-z]{2}\\\\d+'), concat(substring(regexReplace(ci, '[-_]', ''), 3, length(regexReplace(ci, '[-_]', ''))-2), '-', substring(regexReplace(ci, '[-_]', ''), 1, 2)), iif(rlike(regexReplace(ci, '[-_]', ''), '\\\\d+[A-Za-z]{2}$'), concat(substring(regexReplace(ci, '[-_]', ''), 1, length(regexReplace(ci, '[-_]', ''))-2), '-', right(regexReplace(ci, '[-_]', ''), 2)), regexReplace(ci, '[-_]', '')))),",
				"          nombres = initCap(trim(nombres)),",
				"          apellido_paterno = iif(isNull(apellido_paterno) || trim(apellido_paterno) == '', '', initCap(trim(apellido_paterno))),",
				"          apellido_materno = iif(isNull(apellido_materno) || trim(apellido_materno) == '', '', initCap(trim(apellido_materno))),",
				"          nombre_completo = initCap(trim(concat(nombres, ' ', iif(isNull(apellido_paterno), '', apellido_paterno), ' ', iif(isNull(apellido_materno), '', apellido_materno)))),",
				"          fecha_nacimiento = iif(instr(fecha_nacimiento, '/') > 0, toDate(fecha_nacimiento, 'dd/MM/yyyy'), iif(instr(fecha_nacimiento, '-') == 3, toDate(fecha_nacimiento, 'dd-MM-yyyy'), toDate(fecha_nacimiento, 'yyyy-MM-dd'))),",
				"          genero = initCap(trim(genero)),",
				"          estado_civil = initCap(trim(estado_civil)),",
				"          municipio = initCap(trim(municipio))) ~> derivedColumn2",
				"source1 select(mapColumn(",
				"          ci = CI,",
				"          nombres = Nombres,",
				"          apellido_paterno = {Ap. Paterno},",
				"          apellido_materno = {Ap. Materno},",
				"          fecha_nacimiento = {Fecha Nac.},",
				"          genero = {Género},",
				"          estado_civil = {Estado Civil},",
				"          municipio = Municipio",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"derivedColumn2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          ci as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          nombre_completo as string,",
				"          fecha_nacimiento as date,",
				"          genero as string,",
				"          estado_civil as string,",
				"          municipio as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          ci,",
				"          nombres,",
				"          apellido_paterno,",
				"          apellido_materno,",
				"          nombre_completo,",
				"          fecha_nacimiento,",
				"          genero,",
				"          estado_civil,",
				"          municipio",
				"     )) ~> sink1"
			]
		}
	}
}