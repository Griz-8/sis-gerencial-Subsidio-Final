{
	"name": "df_bronze_to_silver_as_vehiculos",
	"properties": {
		"folder": {
			"name": "bronze_to_silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_sql_bronze_as_vehiculos",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sql_silver_as_vehiculos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          vehiculo_id as string,",
				"          transportista_id as string,",
				"          descripcion as string,",
				"          placa as string,",
				"          tipo as string,",
				"          capacidad_kg as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 derive(vehiculo_id = toInteger(vehiculo_id),",
				"          transportista_id = toInteger(vehiculo_id),",
				"          capacidad_kg = toDecimal(capacidad_kg, 10, 2),",
				"          placa = upper(trim(placa)),",
				"          tipo = upper(trim(tipo)),",
				"          estado = upper(trim(estado))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          vehiculo_id as integer,",
				"          transportista_id as integer,",
				"          descripcion as string,",
				"          placa as string,",
				"          tipo as string,",
				"          capacidad_kg as decimal(10,2),",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          vehiculo_id,",
				"          transportista_id,",
				"          descripcion,",
				"          placa,",
				"          tipo,",
				"          capacidad_kg,",
				"          estado",
				"     )) ~> sink1"
			]
		}
	}
}