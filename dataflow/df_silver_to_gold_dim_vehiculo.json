{
	"name": "df_silver_to_gold_dim_vehiculo",
	"properties": {
		"folder": {
			"name": "silver_to_gold/dim2"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_sql_silver_as_vehiculos",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sql_gold_vehiculo",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          vehiculo_id as integer,",
				"          transportista_id as integer,",
				"          descripcion as string,",
				"          placa as string,",
				"          tipo as string,",
				"          capacidad_kg as decimal(10,2),",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 derive(descripcion = trim(upper(descripcion)),",
				"          placa = trim(upper(placa)),",
				"          tipo = trim(upper(tipo)),",
				"          estado = trim(upper(estado))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          vehiculo_key as integer,",
				"          vehiculo_id as integer,",
				"          descripcion as string,",
				"          placa as string,",
				"          tipo as string,",
				"          capacidad_kg as decimal(10,2),",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          vehiculo_id,",
				"          descripcion,",
				"          placa,",
				"          tipo,",
				"          capacidad_kg,",
				"          estado",
				"     )) ~> sink1"
			]
		}
	}
}